# Environment Configuration Template

# Server Configuration
PORT=3000
NODE_ENV=development
DEBUG=ci-agent:*

# GitLab Configuration
# Generate token at: https://gitlab.com/-/user_settings/personal_access_tokens
# Required scopes: api, read_api
GITLAB_TOKEN=glpat_xxxxxxxxxxxxx
GITLAB_API_BASE=https://gitlab.com/api/v4

# Slack Configuration
# Webhook URL for CI Agent channel
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Featherless AI
# Get API key at: https://www.featherless.ai
# Used for LLM-powered error classification
FEATHERLESS_API_KEY=ftr_xxxxxxxxxxxxx

# Bright Data (Optional)
# Get API key at: https://brightdata.com
# Used for external signal enrichment
BRIGHTDATA_API_KEY=xxxxxxxxxxxxx

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Safety Limits (optional overrides)
# Maximum automatic retries per pipeline
MAX_RETRIES_PER_PIPELINE=2

# Minimum confidence threshold for automatic action (0-1)
MIN_CONFIDENCE_FOR_ACTION=0.75

# Action timeout in milliseconds
ACTION_TIMEOUT=30000
